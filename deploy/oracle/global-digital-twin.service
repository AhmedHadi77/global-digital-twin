[Unit]
Description=Global Digital Twin Backend
After=network.target

[Service]
Type=simple
User=__APP_USER__
Group=__APP_USER__
WorkingDirectory=__APP_DIR__/backend
EnvironmentFile=__APP_DIR__/backend/.env
ExecStart=/usr/bin/node __APP_DIR__/backend/server.js
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
